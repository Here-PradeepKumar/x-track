{
  "expo": {
    "name": "X-TRACK",
    "slug": "x-track",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#0e0e0f"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.xtrack.athlete"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0e0e0f"
      },
      "package": "com.xtrack.athlete",
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-font",
      ["expo-media-library", {
        "photosPermission": "Allow X-TRACK to save your race results to your gallery."
      }]
    ],
    "extra": {
      "eas": {
        "projectId": "d22ed99b-91c3-46b1-a5f1-47aacbd8e350"
      }
    }
  }
}
