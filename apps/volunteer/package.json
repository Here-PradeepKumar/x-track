{
  "name": "@x-track/volunteer",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "test": "jest"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFilesAfterEnv": [
      "@testing-library/jest-native/extend-expect"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg|@x-track/.*|firebase|@firebase/.*)"
    ],
    "moduleNameMapper": {
      "^@x-track/firebase$": "<rootDir>/../../packages/firebase/src/index.ts",
      "^@x-track/ui$": "<rootDir>/../../packages/ui/index.ts"
    }
  },
  "dependencies": {
    "@expo-google-fonts/inter": "^0.2.3",
    "@expo-google-fonts/lexend": "^0.2.3",
    "@expo/vector-icons": "^14.0.0",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@react-navigation/bottom-tabs": "^6.5.20",
    "@react-navigation/native": "^6.1.17",
    "@x-track/firebase": "*",
    "@x-track/ui": "*",
    "expo": "~51.0.0",
    "expo-font": "~12.0.5",
    "expo-linear-gradient": "~13.0.2",
    "expo-splash-screen": "~0.27.4",
    "expo-status-bar": "~1.12.1",
    "firebase": "^10.12.0",
    "react": "18.2.0",
    "react-native": "^0.74.5",
    "react-native-nfc-manager": "^3.14.14",
    "react-native-safe-area-context": "^4.10.5",
    "react-native-screens": "3.31.1",
    "react-native-webview": "~13.8.6"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "@types/react": "~18.2.45",
    "jest": "^29.7.0",
    "jest-expo": "^51.0.4",
    "react-test-renderer": "^18.2.0",
    "typescript": "~5.3.3"
  },
  "private": true,
  "expo": {
    "install": {
      "exclude": [
        "react-native-webview"
      ]
    }
  }
}
