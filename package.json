{
  "name": "x-track-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "athlete": "npm run start --workspace=apps/athlete",
    "volunteer": "npm run start --workspace=apps/volunteer",
    "web": "npm run dev --workspace=apps/web",
    "functions:build": "npm run build --workspace=firebase/functions",
    "functions:deploy": "firebase deploy --only functions",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
  "devDependencies": {
    "typescript": "~5.3.3"
  },
  "dependencies": {
    "expo": "~51.0.28",
    "react": "18.2.0",
    "react-native": "0.74.5",
    "react-native-webview": "~13.8.6"
  },
  "overrides": {
    "react": "18.2.0",
    "react-dom": "18.2.0"
  }
}
